#!/usr/bin/env python3

import sys
import textwrap

if sys.platform == "darwin":
    filePath = "/opt/homebrew/sealsay/seals"
elif sys.platform == "linux":
    filePath = "/usr/share/sealsay/seals"

def printSeal(usrInput, sealInput, filePath):
    match sealInput.lower():
        case "-s":
            f = open(f"{filePath}/basicseal.txt", "r")
            sealArt = f.read()
            f.close()
        
        case "-t":
            f = open(f"{filePath}/tiredseal.txt", "r")
            sealArt = f.read()
            f.close()

        case "-l":
            f = open(f"{filePath}/sealion.txt", "r")
            sealArt = f.read()
            f.close()
        

    lines = textwrap.wrap(usrInput, width=40)
    width = max(len(l) for l in lines)
    border = "-" * (width + 4)
    
    
    bubble = f"{border}\n"
    for line in lines:
        bubble += f"    <  {line}  >\n"
    bubble += f"     {border}"
    

    print(rf"""
     {bubble}
{sealArt}                                                      
      """)

    
if __name__ == "__main__":
    if len(sys.argv) > 1:
        sealInput = " ".join(sys.argv[1:2])
        usrInput = " ".join(sys.argv[2:])
        printSeal(usrInput, sealInput)
    else:
        print("Invalid use! Please use this format;" \
        "sealsay -[selector] [message]")

