#!/usr/bin/env python3

from pathlib import Path
import textwrap
import platform
import random
import sys

import argparse

# the magic numbers in sys.exit were pmo AND os.EX_* stuff isnt cross-platform, so stupid
EXIT_OK             = 0
EXIT_ERROR          = 1
EXIT_USAGE          = 2
EXIT_NOT_FOUND      = 3
EXIT_INVALID_SEAL   = 4
EXIT_IO_ERROR       = 5
EXIT_CONFIG_ERROR   = 6
EXIT_INTERRUPTED    = 130 # (128 + SIGINT is how unix does it)
EXIT_BROKEN_PIPE    = 141 # (128 + SIGPIPE is also how unix does it lol)

filePath = "seals/"
if (platform.system() == "Linux"):
    filePath = Path("/usr/share/seals")
elif (platform.system() == "Darwin"):
    filePath = Path("/usr/local/share/seals")
else:
    filePath = Path("seals") # fb

# finds all .txt's in filePath (seals dir), stems them to first char and makes a list of callable flags
# from the stems.
#
# New seals now wont require code changes, just a new .txt
# 
# should probably do something about overlapping file names (e.g: if two files start with the same letter)
# could make them use more chars sequentially till it finds a unique flag
def _build_seal_map():
    if not filePath.is_dir():
        sys.exit(EXIT_CONFIG_ERROR)
    
    return {f"-{p.stem[0]}": p.name for p in sorted(filePath.glob("*.txt"))}

SEALS = _build_seal_map()

def build_parser():
    p = argparse.ArgumentParser(
        prog="sealsay",
        description="CLI app that generates ASCII art of a seal saying a message",
        formatter_class=argparse.RawDescriptionHelpFormatter, # turns off text wrapping in epilog
        epilog=("e.g usage:\n"
                f"{"":<{3}}sealsay -s 'Hello, world!' # uses the 'basic' seal\n"
                f"{"":<{3}}sealsay -r Hi              # chooses a random seal") # ^ same length text ugh so hot and sexy

    )
    p.add_argument("message", nargs="*", help="text for the seal to say")
    p.add_argument("-l", "--list", action="store_true", help="lists all seals")
    p.add_argument("-r", "--random", action="store_true", help="pick a random seal to display your message")
    p.add_argument("-n", "--no-wrap", action="store_true", help="disable text wrapping")
    
    appearance = p.add_argument_group("appearance")
    appearance.add_argument("-B", "--bold", action="store_true", help="makes bubble text bolded")
    
    seals = p.add_argument_group("seals")
    seal_choice = seals.add_mutually_exclusive_group(required=False)
    for flag in sorted(SEALS):
        name = Path(SEALS[flag]).stem
        seal_choice.add_argument(flag, f"--{name}", dest="seal", action="store_const", const=flag, help=f"{name} seal")
    
    seal_choice.add_argument("-s", "--say", dest="seal", action="store_const", const="-b", help="Says something with the og seal")
    
    return p

def main():
    parser = build_parser()
    args = parser.parse_args()
    
    if args.list:
        list_seals()
        return
    
    if args.random:
        args.seal = random.choice(list(SEALS.keys()))
    
    message = " ".join(args.message)
    if not message and not sys.stdin.isatty():
        message = read_stdin()
            
    if (sealArt := selectSeal(args.seal)) is None:
        parser.error(f'please provide something so we can make seal instead of "{args.seal}"')
        sys.exit(EXIT_INVALID_SEAL)
        
    printSeal(message=message, sealArt=sealArt, no_wrap=args.no_wrap, bold=args.bold)
    
def read_stdin():
    try: 
        return sys.stdin.read().rstrip("\n")
    except KeyboardInterrupt:
        sys.exit(EXIT_INTERRUPTED)
    except (OSError, UnicodeDecodeError) as e:
        print(f"Error when reading from stdin: {e}", file=sys.stderr)
        sys.exit(EXIT_IO_ERROR)

def list_seals():
    if not SEALS:
        print(f"No seals found in {filePath}", file=sys.stderr)
        sys.exit(EXIT_NOT_FOUND)
    
    print("Available seals:")
    for flag in sorted(SEALS):
        print(f"{"":<{3}}{flag} {Path(SEALS[flag]).stem}")

def printSeal(message, sealArt, no_wrap=False, bold=False):
    message = message or ""
    
    lines = []
    for paragraph in message.split("\n"):
        if no_wrap:
            lines.extend(paragraph)
        else:
            lines.extend(textwrap.wrap(paragraph, width=40) or [""]) 
    
    width = max(len(l) for l in lines)
    
    # helper func for border deduplication
    def border(char):
        leader      = " "
        inner_width = (width + 2)
        
        return leader + char * inner_width
    
    top     = border("_")
    bottom  = border("-")
    
    if len(lines) == 1:
        body = f"< {lines[0].ljust(width)} >"
    else:
        body_lines = []
        
        last = len(lines) - 1
        sides = {0: ("/", "\\"), last: ("\\", "/")}
        
        for i, line in enumerate(lines):
            left, right = sides.get(i, ("|", "|"))
            body_lines.append(f"{left} {line.ljust(width)} {right}")
        
        # old way, im not sure if above covers all edge cases, so ill leave it here for now
        # for i, line in enumerate(lines):
        #     if i == 0:
        #         left, right = "/", "\\"
        #     elif i == len(lines) - 1:
        #         left, right = "\\", "/"
        #     else:
        #         left, right = "|", "|"
            
        #     body_lines.append(f"{left} {line.ljust(width)} {right}")
        
        body = "\n".join(body_lines)
        
    output = f"{top}\n{body}\n{bottom}\n{sealArt}"
    if bold:
        print(f"bold is {bold}", file=sys.stderr)
        output = f"\x1b[1m{output}\x1b[0m"

    print(output)


def selectSeal(sealVar):
    if sealVar not in SEALS:
        return None
    
    path = filePath / SEALS[sealVar]
    
    try:
        with open(path, encoding="utf-8") as f:
            return f.read()
    except FileNotFoundError:
        print(f"Error: seal file not found: {path}", file=sys.stderr)
        sys.exit(EXIT_INVALID_SEAL)

if __name__ == "__main__": main()