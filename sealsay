#!/usr/bin/env python3

import sys
import textwrap
import platform

filePath = "seals/"
if (platform.system() == "Linux"):
    filePath = "/usr/share/seals/"
elif (platform.system() == "Darwin"):
    filePath = "/usr/local/share/seals/"
# detects which os for file path, because macOS doesn't like things being installed
# to /usr/share/

def main():
    if len(sys.argv) > 1:
        sealVar = sys.argv[1]
        usrInput = " ".join(sys.argv[2:])
        sealArt = selectSeal(sealVar)
        if sealArt == 2:
            print("Usage: sealsay [-modifier] [message]\nNOTE: Message MUST be preceded by a modifier\nMODIFIERS:\nSeal variants:\n-s, -o, -t\n\nOther modifiers:\n-h")
        elif sealArt == 0:
            print("Error: no sealfile attached to modifier")
        elif sealArt:
            printSeal(usrInput, sealArt)
        else:
            print("Error: Incorrect usage. See \"sealsay -h\" for help.")

def printSeal(usrInput, sealArt):    
    usrInput = usrInput or ""
    
    lines = []
    for paragraph in usrInput.split("\n"):
        lines.extend(textwrap.wrap(paragraph, width=40) or [""])
    
    width = max(len(l) for l in lines)
    
    # helper func for border deduplication
    def border(char):
        leader      = " "
        inner_width = (width + 2)
        
        return leader + char * inner_width
    
    top     = border("_")
    bottom  = border("-")
    
    if len(lines) == 1:
        body = f"< {lines[0].ljust(width)} >"
    else:
        body_lines = []
        
        last = len(lines) - 1
        sides = {0: ("/", "\\"), last: ("\\", "/")}
        
        for i, line in enumerate(lines):
            left, right = sides.get(i, ("|", "|"))
            body_lines.append(f"{left} {line.ljust(width)} {right}")
        
        # old way, im not sure if above covers all edge cases, so ill leave it here for now
        # for i, line in enumerate(lines):
        #     if i == 0:
        #         left, right = "/", "\\"
        #     elif i == len(lines) - 1:
        #         left, right = "\\", "/"
        #     else:
        #         left, right = "|", "|"
            
        #     body_lines.append(f"{left} {line.ljust(width)} {right}")
        
        body = "\n".join(body_lines)

    print(f"{top}\n{body}\n{bottom}\n{sealArt}")


def selectSeal(sealVar):
    x = 0
    if (sealVar == "-s"):
        with open(f"{filePath}basicseal.txt") as f:
            x = f.read()
            return x
    elif (sealVar == "-o"):
        with open(f"{filePath}oldseal.txt") as f:
            x = f.read()
            return x
    elif (sealVar == "-t"):
        with open(f"{filePath}triple.txt") as f:
            x = f.read()
            return x
    elif (sealVar == "-h"):
        return 2
    else:
        return 0

if __name__ == "__main__": main()