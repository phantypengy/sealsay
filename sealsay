RED, GREEN, YELLOW, BLUE, MAGENTA, CYAN = 31, 32, 33, 34, 35, 36
RAINBOW_COLORS = [RED, GREEN, YELLOW, BLUE, MAGENTA, CYAN]
RAINBOW_FREQ   = 0.1

filePath = "seals/"
if (platform.system() == "Linux"):
    filePath = Path("/usr/share/seals")
elif (platform.system() == "Darwin"):
    filePath = Path("/usr/local/share/seals")
else:
    filePath = Path("seals") # fb

def _make_parser_skeleton():
    p = argparse.ArgumentParser(
        prog="sealsay",
        description="CLI app that generates ASCII art of a seal saying a message",
        formatter_class=argparse.RawDescriptionHelpFormatter, # turns off text wrapping in epilog
        epilog=("e.g usage:\n"
                f"{"":<{3}}sealsay -s 'Hello, world!' # uses the 'basic' seal\n"
                f"{"":<{3}}sealsay -r Hi              # chooses a random seal") # ^ same length text ugh so hot and sexy

    )
    p.add_argument("message", nargs="*", help="text for the seal to say")
    p.add_argument("-l", "--list", action="store_true", help="lists all seals")
    p.add_argument("-r", "--random", action="store_true", help="pick a random seal to display your message")
    p.add_argument("-n", "--no-wrap", action="store_true", help="disable text wrapping")
    p.add_argument("-w", "--wrap", type=int, default=40, metavar="int", help="wrap column after a given amount of chars (default = 40)")
    p.add_argument("-e", "--eyes", default=None, metavar="EE", help="gives your seal eyes!! comma seperated for seals with multiple eyes. e.g 'aa,bb,cc'")
    p.add_argument("-T", "--tongues", default=None, metavar="TT", help="gives your seal a tongue!! comma seperated for seals with multiple tongues. e.g 'aa,bb,cc'")

    
    appearance = p.add_argument_group("appearance")
    appearance.add_argument("-B", "--bold", action="store_true", help="makes bubble text bolded")
    appearance.add_argument("-R", "--rainbow", action="store_true", help="makes bubble text rainbow")
    appearance.add_argument("-A", "--aurora", action="store_true", help="makes bubble text aurora'd")

    seal_group  = p.add_argument_group("seals")
    seal_choice = seal_group.add_mutually_exclusive_group(required=False)
    say_action  = seal_choice.add_argument("-s", "--say", dest="seal", action="store_const", const=None, help="says something with the og seal")

    return p, seal_choice, say_action

def _reserved_flags():
    skeleton, _, _ = _make_parser_skeleton()
    short, long_ = set(), set()
    for opt in skeleton._option_string_actions:
        if opt.startswith("--"):
            long_.add(opt[2:])
        elif len(opt) == 2:
            short.add(opt[1])
    return frozenset(short), frozenset(long_)

_RESERVED_SHORT, _RESERVED_LONG = _reserved_flags()

# finds all .txt's in filePath (seals dir), stems them to first char and makes a list of callable flags
# from the stems.
#
# New seals now wont require code changes, just a new .txt
#
# Flag collisions are handled by extending prefix by one char until a unique flag is found
# we also check if the flag is reserved by our cli's actual flags
def _build_seal_map():
    if not filePath.is_dir():
        sys.exit(EXIT_CONFIG_ERROR)

    seals = {}
    used_short = set(_RESERVED_SHORT)
    for p in sorted(filePath.glob("*.txt")):
        stem = p.stem
        n = 1
        while n <= len(stem) and stem[:n] in used_short:
            n += 1
        if n > len(stem):
            seals[f"--{stem}"] = p.name
        else:
            prefix = stem[:n]
            used_short.add(prefix)
            seals[f"-{prefix}"] = p.name
    return seals

SEALS = _build_seal_map()

def build_parser():
    p, seal_choice, say_action = _make_parser_skeleton()

    for flag in sorted(SEALS):
        name = Path(SEALS[flag]).stem
        long_flag = f"--{name}"
        # skip if long name == short name or if it is reserved by cli
        flags = [flag] if flag == long_flag or name in _RESERVED_LONG else [flag, long_flag]
        seal_choice.add_argument(*flags, dest="seal", action="store_const", const=flag, help=f"{name} seal")

    basic_flag = next((f for f, n in SEALS.items() if Path(n).stem == "basic"), None)
    if basic_flag:
        say_action.const = basic_flag

    return p

def main():
    parser = build_parser()
    args = parser.parse_args()
    
    if args.list:
        list_seals()
        return
    
    if args.random:
        args.seal = random.choice(list(SEALS.keys()))
    
    message = " ".join(args.message)
    if not message and not sys.stdin.isatty():
        message = read_stdin()
            
    if (sealArt := selectSeal(args.seal, eyes=args.eyes, tongues=args.tongues)) is None:
        parser.error(f'please provide something so we can make seal instead of "{args.seal}"')
        
    printSeal(message=message, sealArt=sealArt, no_wrap=args.no_wrap, wrap=args.wrap, bold=args.bold, rainbow=args.rainbow, aurora=args.aurora)
    
def read_stdin():
    try: 
        return sys.stdin.read().rstrip("\n")
    except KeyboardInterrupt:
        sys.exit(EXIT_INTERRUPTED)
    except (OSError, UnicodeDecodeError) as e:
        print(f"Error when reading from stdin: {e}", file=sys.stderr)
        sys.exit(EXIT_IO_ERROR)

def list_seals():
    if not SEALS:
        print(f"No seals found in {filePath}", file=sys.stderr)
        sys.exit(EXIT_NOT_FOUND)
    
    print("Available seals:")
    for flag in sorted(SEALS):
        print(f"{"":<{3}}{flag} {Path(SEALS[flag]).stem}")
    
# helper to dedupe the colorizers 
def _colorize(text, color_for, bold=False, reset_on_nl=False):
    attr = ";1" if bold else ""
    buf = []
    i = 0
    
    for ch in text:
        if ch == "\n":
            if reset_on_nl:
                i = 0
                
            buf.append(ch)
            continue
        
        buf.append(f"\x1b[{color_for(i)}{attr}m{ch}\x1b[0m")
        i += 1
    
    return "".join(buf)

# this is such a shit function but idc
def _aurora_index(i):
    r = int(6 * ((math.sin(RAINBOW_FREQ * i + 0) * 127 + 128)                / 256)) * 36
    g = int(6 * ((math.sin(RAINBOW_FREQ * i + 2  * (math.pi/3)) * 127 + 128) / 256)) * 6
    b = int(6 * ((math.sin(RAINBOW_FREQ * i + 4  * (math.pi/3)) * 127 + 128) / 256)) * 1
    
    return 16 + r + g + b
        
def rainbow_print(text, bold=False):
    return _colorize(
        text,
        color_for=lambda i: str(RAINBOW_COLORS[i % 6]),
        bold=bold,
        reset_on_nl=True
    )

def aurora_print(text, bold=False, start=0):
    return _colorize(
        text,
        color_for=lambda i: f"38;5;{_aurora_index(i)}",
        bold=bold
    )

# strips '# eye: value' and returns (sealArt, defaults)
def _parse_seal(raw):
    defaults = {}
    lines = raw.splitlines(keepends=True)
    body_start = 0
    
    for i, line in enumerate(lines):
        stripped = line.lstrip()
        if stripped.startswith("#") and ":" in stripped:
            key, _, val = stripped[1:].partition(":")
            defaults[key.strip()] = val.strip()
            body_start = i + 1
        else:
            break
        
    return "".join(lines[body_start:]), defaults

def _parse_braced(mark):
    parts = []
    regions = []
    pos = 0
    i = 0
    
    while i < len(mark):
        if mark[i] == "{":
            close = mark.find("}", i + 1)
            if close < 0:
                parts.append(mark[i])
                pos += 1
                i += 1
                continue
            region = mark[i + 1:close]
            parts.append(region)
            regions.append((pos, len(region)))
            pos += len(region)
            i = close + 1
        else:
            parts.append(mark[i])
            pos += 1
            i += 1

    return "".join(parts), regions

def _fill_regions(literal, regions, user_input):
    out = []
    last = 0
    idx = 0
    
    for start, width in regions:
        out.append(literal[last:start])
        out.append(user_input[idx:idx + width].ljust(width))
        idx += width
        last = start + width
        
    out.append(literal[last:])
    return "".join(out)

def printSeal(message, sealArt, no_wrap=False, wrap=40, bold=False, rainbow=False, aurora=False):
    message = message or ""
    
    lines = []
    for paragraph in message.split("\n"):
        if no_wrap:
            lines.append(paragraph)
        else:
            lines.extend(textwrap.wrap(paragraph, width=wrap) or [""]) 
    
    width = max(len(l) for l in lines)
    
    # helper func for border deduplication
    def border(char):
        leader      = " "
        inner_width = (width + 2)
        
        return leader + char * inner_width
    
    top     = border("_")
    bottom  = border("-")
    
    if len(lines) == 1:
        body = f"< {lines[0].ljust(width)} >"
    else:
        body_lines = []
        
        last = len(lines) - 1
        sides = {0: ("/", "\\"), last: ("\\", "/")}
        
        for i, line in enumerate(lines):
            left, right = sides.get(i, ("|", "|"))
            body_lines.append(f"{left} {line.ljust(width)} {right}")
        body = "\n".join(body_lines)
        
    output = f"{top}\n{body}\n{bottom}\n{sealArt}"
    
    if rainbow:
        output = rainbow_print(output, bold=bold)
    elif aurora:
        output = aurora_print(output, bold=bold)
    elif bold:
        output = f"\x1b[1m{output}\x1b[0m"

    print(output)


def selectSeal(sealVar, eyes, tongues):
    if sealVar not in SEALS:
        return None
    
    path = filePath / SEALS[sealVar]
    
    try:
        with open(path, encoding="utf-8") as f:
            raw = f.read()
    except FileNotFoundError:
        print(f"Error: seal file not found: {path}", file=sys.stderr)
        sys.exit(EXIT_INVALID_SEAL)
    
    art, default = _parse_seal(raw)
    eye_pairs = [p.strip() for p in default.get("eyes", "").split(",") if p.strip()]
    
    if eyes is not None and eye_pairs:
        user_eyes = [e.strip() for e in eyes.split(",")]
        
        if len(user_eyes) == 1:
            user_eyes = user_eyes * len(eye_pairs) # if only one eye pair is provided, apply to all eyes in the file
        
        for original_pair, new_eye in zip(eye_pairs, user_eyes):
            literal, regions = _parse_braced(original_pair)
            art = art.replace(literal, _fill_regions(literal, regions, new_eye), 1)

    tongue_marks = [t.strip() for t in default.get("tongues", "").split(",") if t.strip()]

    if tongues is not None and tongue_marks:
        user_tongues = [t.strip() for t in tongues.split(",")]

        if len(user_tongues) == 1:
            user_tongues = user_tongues * len(tongue_marks)

        for original_mark, new_tongue in zip(tongue_marks, user_tongues):
            literal, regions = _parse_braced(original_mark)
            art = art.replace(literal, _fill_regions(literal, regions, new_tongue), 1)

    return art

if __name__ == "__main__": main()