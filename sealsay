#!/usr/bin/env python3

import sys
import textwrap
import platform

filePath = "seals/"
if (platform.system() == "Linux"):
    filePath = "/usr/share/seals/"
elif (platform.system() == "Darwin"):
    filePath = "/usr/local/share/seals/"
# detects which os for file path, because macOS doesn't like things being installed
# to /usr/share/

def main():
    if len(sys.argv) > 1:
        sealVar = sys.argv[1]
        usrInput = " ".join(sys.argv[2:])
        sealArt = selectSeal(sealVar)
        if sealArt == 2:
            print("Usage: sealsay [-modifier] [message]\nNOTE: Message MUST be preceded by a modifier\nMODIFIERS:\nSeal variants:\n-s, -o, -t\n\nOther modifiers:\n-h")
        elif sealArt == 0:
            print("Error: no sealfile attached to modifier")
        elif sealArt:
            printSeal(usrInput, sealArt)
        else:
            print("Error: Incorrect usage. See \"sealsay -h\" for help.")

def printSeal(usrInput, sealArt):
    usrInput = usrInput or ""
    lines = textwrap.wrap(usrInput, width=40)
    if not lines:
        lines = [""]
    width = max(len(l) for l in lines)
    border = "-" * (width + 4)
    bubble = f"{border}\n"
    
    for line in lines:
        bubble += f"    <  {line}  >\n"
    bubble += f"     {border}"

    print(rf"""
     {bubble}
{sealArt}""")

def selectSeal(sealVar):
    x = 0
    if (sealVar == "-s"):
        with open(f"{filePath}basicseal.txt") as f:
            x = f.read()
            return x
    elif (sealVar == "-o"):
        with open(f"{filePath}oldseal.txt") as f:
            x = f.read()
            return x
    elif (sealVar == "-t"):
        with open(f"{filePath}triple.txt") as f:
            x = f.read()
            return x
    elif (sealVar == "-h"):
        return 2
    else:
        return 0

if __name__ == "__main__": main()