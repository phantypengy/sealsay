#!/usr/bin/env python3

import sys
import textwrap

def printSeal(usrInput, sealInput):
    match sealInput.lower():
        case "-s":
            f = open("/usr/share/sealsay/seals/basicseal.txt", "r")
            sealArt = f.read()
            f.close()
        
        case "-t":
            f = open("/usr/share/sealsay/seals/tiredseal.txt", "r")
            sealArt = f.read()
            f.close()

        case "-l":
            f = open("/usr/share/sealsay/seals/sealion.txt", "r")
            sealArt = f.read()
            f.close()
        

    lines = textwrap.wrap(usrInput, width=40)
    width = max(len(l) for l in lines)
    border = "-" * (width + 4)
    
    
    bubble = f"{border}\n"
    for line in lines:
        bubble += f"    <  {line}  >\n"
    bubble += f"     {border}"
    

    print(rf"""
     {bubble}
{sealArt}                                                      
      """)

    
if __name__ == "__main__":
    if len(sys.argv) > 1:
        sealInput = " ".join(sys.argv[1:2])
        usrInput = " ".join(sys.argv[2:])
        printSeal(usrInput, sealInput)
    else:
        print("Invalid use! Please provide a message for the seal to say.")
